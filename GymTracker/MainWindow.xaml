<Window x:Class="GymTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GymTracker" Height="700" Width="1100"
        Background="#1A1A1A"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Estilo base para botones del menú lateral -->
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="Foreground"       Value="#CCCCCC"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Height"           Value="48"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"          Value="20 0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#1D9E75"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="Border" Property="Background" Value="#157A5A"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════ MENÚ LATERAL ═══════════════════════════════ -->
        <Border Grid.Column="0" Background="#111111">
            <DockPanel>
                <!-- Logo / título -->
                <Border DockPanel.Dock="Top" Padding="20 24" BorderThickness="0 0 0 1"
                        BorderBrush="#2A2A2A">
                    <StackPanel>
                        <TextBlock Text="💪" FontSize="28"/>
                        <TextBlock Text="GymTracker"
                                   Foreground="White" FontSize="16" FontWeight="Bold"
                                   Margin="0 4 0 0"/>
                    </StackPanel>
                </Border>

                <!-- Botones de navegación -->
                <StackPanel DockPanel.Dock="Top" Margin="0 12 0 0">
                    <Button x:Name="BtnEjercicios"  Style="{StaticResource NavButton}"
                            Click="BtnEjercicios_Click">
                        <TextBlock>
                            <Run Text="🏋  "/>
                            <Run Text="Ejercicios"/>
                        </TextBlock>
                    </Button>

                    <Button x:Name="BtnRutinas" Style="{StaticResource NavButton}"
                            Click="BtnRutinas_Click">
                        <TextBlock>
                            <Run Text="📋  "/>
                            <Run Text="Rutinas"/>
                        </TextBlock>
                    </Button>

                    <Button x:Name="BtnNuevaSesion" Style="{StaticResource NavButton}"
                            Click="BtnNuevaSesion_Click">
                        <TextBlock>
                            <Run Text="▶  "/>
                            <Run Text="Nueva Sesión"/>
                        </TextBlock>
                    </Button>

                    <Button x:Name="BtnHistorial" Style="{StaticResource NavButton}"
                            Click="BtnHistorial_Click">
                        <TextBlock>
                            <Run Text="📅  "/>
                            <Run Text="Historial"/>
                        </TextBlock>
                    </Button>

                    <Button x:Name="BtnProgresion" Style="{StaticResource NavButton}"
                            Click="BtnProgresion_Click">
                        <TextBlock>
                            <Run Text="📈  "/>
                            <Run Text="Progresión"/>
                        </TextBlock>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══════════════════════════════ ÁREA DE CONTENIDO ═══════════════════════════════ -->
        <ContentControl x:Name="MainContent"
                        Grid.Column="1"
                        Background="#1A1A1A"/>
    </Grid>
</Window>
