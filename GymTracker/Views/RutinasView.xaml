<UserControl x:Class="GymTracker.Views.RutinasView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="FormColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════ PANEL PRINCIPAL ═══════════ -->
        <Grid Grid.Column="0" Margin="24">
            <Grid.RowDefinitions>
                <!-- Cabecera -->
                <RowDefinition Height="Auto"/>
                <!-- DataGrid rutinas -->
                <RowDefinition Height="*" MinHeight="160"/>
                <!-- Panel de asignación de ejercicios -->
                <RowDefinition x:Name="AsignacionRow" Height="0"/>
            </Grid.RowDefinitions>

            <!-- Cabecera -->
            <DockPanel Grid.Row="0" Margin="0 0 0 16">
                <TextBlock Text="Rutinas" FontSize="22" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource AccentButton}"
                        Content="+ Nueva Rutina"
                        Click="BtnNuevaRutina_Click"/>
            </DockPanel>

            <!-- DataGrid de rutinas -->
            <DataGrid x:Name="GridRutinas" Grid.Row="1"
                      SelectionChanged="GridRutinas_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nombre"       Binding="{Binding Nombre}"                         Width="200"/>
                    <DataGridTextColumn Header="Descripción"  Binding="{Binding Descripcion}"                    Width="*"/>
                    <DataGridTextColumn Header="Fecha Creación"
                                        Binding="{Binding FechaCreacion, StringFormat={}{0:dd/MM/yyyy}}"         Width="130"/>
                    <DataGridTemplateColumn Header="" Width="160">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Editar"
                                            Style="{StaticResource RowButton}"
                                            Tag="{Binding}"
                                            Margin="0 0 6 0"
                                            Click="BtnEditarRutina_Click"/>
                                    <Button Content="Eliminar"
                                            Style="{StaticResource DangerButton}"
                                            Tag="{Binding}"
                                            Click="BtnEliminarRutina_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- ═══════════ PANEL ASIGNACIÓN DE EJERCICIOS ═══════════ -->
            <Border Grid.Row="2" Background="#111111" Padding="16" Margin="0 12 0 0"
                    CornerRadius="4">
                <DockPanel>
                    <!-- Título del panel -->
                    <TextBlock x:Name="TxtTituloAsignacion"
                               DockPanel.Dock="Top"
                               Text="Ejercicios de la rutina"
                               FontSize="15" FontWeight="SemiBold"
                               Margin="0 0 0 12"/>

                    <!-- Fila: añadir ejercicio -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                Margin="0 0 0 12">
                        <ComboBox x:Name="CmbEjercicioAsignar"
                                  Width="220" Margin="0 0 8 0">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Nombre}" Foreground="White"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox x:Name="CmbDiaSemana"
                                 
                                  Width="130" Margin="0 0 8 0"/>
                        <Button Content="+ Añadir"
                                Style="{StaticResource AccentButton}"
                                Click="BtnAnadirEjercicio_Click"/>
                    </StackPanel>

                    <!-- DataGrid ejercicios asignados -->
                    <DataGrid x:Name="GridEjerciciosAsignados" MaxHeight="180">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Ejercicio" Binding="{Binding NombreEjercicio}" Width="*"/>
                            <DataGridTextColumn Header="Día"       Binding="{Binding DiaSemana}"       Width="110"/>
                            <DataGridTextColumn Header="Orden"     Binding="{Binding Orden}"           Width="60"/>
                            <DataGridTemplateColumn Header="" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Quitar"
                                                Style="{StaticResource DangerButton}"
                                                Tag="{Binding}"
                                                Click="BtnQuitarEjercicio_Click"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══════════ PANEL FORMULARIO LATERAL ═══════════ -->
        <Border Grid.Column="1" Background="#111111" Padding="24">
            <StackPanel>
                <TextBlock x:Name="FormTitulo" Text="Nueva Rutina"
                           FontSize="18" FontWeight="Bold" Margin="0 0 0 24"/>

                <TextBlock Text="Nombre *" Margin="0 0 0 4"/>
                <TextBox x:Name="TxtNombre"
                         Style="{StaticResource DarkTextBox}"
                         Margin="0 0 0 16"/>

                <TextBlock Text="Descripción" Margin="0 0 0 4"/>
                <TextBox x:Name="TxtDescripcion"
                         Style="{StaticResource DarkTextBox}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         Height="100" VerticalScrollBarVisibility="Auto"
                         Margin="0 0 0 24"/>

                <Button x:Name="BtnGuardar"
                        Style="{StaticResource AccentButton}"
                        Content="Guardar"
                        Margin="0 0 0 8"
                        Click="BtnGuardar_Click"/>
                <Button Style="{StaticResource SecondaryButton}"
                        Content="Cancelar"
                        Click="BtnCancelar_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
