<UserControl x:Class="GymTracker.Views.SesionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="24">

        <!-- Cabecera -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Nueva Sesión" FontSize="22" FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <!-- Botón guardar (anclado abajo) -->
        <Button DockPanel.Dock="Bottom"
                Style="{StaticResource AccentButton}"
                Content="💾  Guardar Sesión"
                FontSize="15" Height="44"
                HorizontalAlignment="Right"
                Margin="0 16 0 0"
                Click="BtnGuardarSesion_Click"/>

        <!-- Formulario superior -->
        <Border DockPanel.Dock="Top" Background="#111111"
                Padding="16" CornerRadius="4" Margin="0 0 0 16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <!-- Rutina -->
                <StackPanel Grid.Column="0" Margin="0 0 16 0">
                    <TextBlock Text="Rutina *" Margin="0 0 0 4"/>
                    <ComboBox x:Name="CmbRutina"
                              SelectedValuePath="Id"
                              SelectionChanged="CmbRutina_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Nombre}" Foreground="White"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>

                <!-- Fecha -->
                <StackPanel Grid.Column="1" Margin="0 0 16 0">
                    <TextBlock Text="Fecha *" Margin="0 0 0 4"/>
                    <DatePicker x:Name="DpFecha"/>
                </StackPanel>

                <!-- Notas -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="Notas (opcional)" Margin="0 0 0 4"/>
                    <TextBox x:Name="TxtNotas"
                             Style="{StaticResource DarkTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="52"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Fila: añadir serie -->
        <Border DockPanel.Dock="Top" Background="#111111"
                Padding="12 10" CornerRadius="4" Margin="0 0 0 12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ejercicio:" VerticalAlignment="Center"
                           Margin="0 0 8 0" Foreground="#AAAAAA"/>
                <ComboBox x:Name="CmbEjercicioSerie"
                          Width="220" Margin="0 0 12 0">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nombre}" Foreground="White"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="+ Añadir Serie"
                        Style="{StaticResource AccentButton}"
                        Click="BtnAnadirSerie_Click"/>
                <TextBlock x:Name="TxtSinEjercicios"
                           Text="⚠ Selecciona una rutina primero"
                           Foreground="#888888" VerticalAlignment="Center"
                           Margin="16 0 0 0" Visibility="Collapsed"/>
            </StackPanel>
        </Border>

        <!-- DataGrid de series -->
        <DataGrid x:Name="GridSeries">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Ejercicio"    Binding="{Binding NombreEjercicio}" Width="*"   IsReadOnly="True"/>
                <DataGridTextColumn Header="Serie"        Binding="{Binding NumSerie}"         Width="60"  IsReadOnly="True"/>
                <DataGridTemplateColumn Header="Repeticiones" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding Repeticiones, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="4 2"
                                     VerticalAlignment="Center"
                                     CaretBrush="White" SelectionBrush="#1D9E75"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Peso (kg)" Width="90">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBox Text="{Binding PesoKg, Mode=TwoWay, UpdateSourceTrigger=LostFocus, StringFormat={}{0:F2}}"
                                     Background="Transparent" Foreground="White"
                                     BorderThickness="0" Padding="4 2"
                                     VerticalAlignment="Center"
                                     CaretBrush="White" SelectionBrush="#1D9E75"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="50">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="✕"
                                    Style="{StaticResource DangerButton}"
                                    Tag="{Binding}"
                                    Click="BtnEliminarSerie_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
