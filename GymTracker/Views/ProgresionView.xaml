<UserControl x:Class="GymTracker.Views.ProgresionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1A1A1A">

    <UserControl.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize"   Value="13"/>
        </Style>

        <!-- Tarjeta de métrica -->
        <Style x:Key="MetricCard" TargetType="Border">
            <Setter Property="Background"    Value="#111111"/>
            <Setter Property="CornerRadius"  Value="6"/>
            <Setter Property="Padding"       Value="20 16"/>
            <Setter Property="Margin"        Value="0 0 12 0"/>
        </Style>
    </UserControl.Resources>

    <DockPanel Margin="24">

        <!-- Cabecera -->
        <TextBlock DockPanel.Dock="Top"
                   Text="Progresión" FontSize="22" FontWeight="Bold"
                   Margin="0 0 0 20"/>

        <!-- Tarjetas de métricas -->
        <UniformGrid DockPanel.Dock="Top" Rows="1" Margin="0 0 0 20">

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="PESO MÁXIMO" Foreground="#888888"
                               FontSize="11" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBlock x:Name="TxtPesoMaximo" Text="—"
                               FontSize="28" FontWeight="Bold" Foreground="#1D9E75"/>
                    <TextBlock x:Name="TxtPesoMaximoLabel" Text="kg"
                               Foreground="#666666" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}">
                <StackPanel>
                    <TextBlock Text="TOTAL SESIONES" Foreground="#888888"
                               FontSize="11" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBlock x:Name="TxtTotalSesiones" Text="—"
                               FontSize="28" FontWeight="Bold" Foreground="#1D9E75"/>
                    <TextBlock Text="registradas" Foreground="#666666" FontSize="12"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCard}" Margin="0">
                <StackPanel>
                    <TextBlock Text="VOLUMEN ÚLTIMO" Foreground="#888888"
                               FontSize="11" FontWeight="Bold" Margin="0 0 0 6"/>
                    <TextBlock x:Name="TxtVolumenUltimo" Text="—"
                               FontSize="28" FontWeight="Bold" Foreground="#1D9E75"/>
                    <TextBlock Text="kg totales (última sesión)" Foreground="#666666" FontSize="12"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <!-- Selectores de gráfica -->
        <Border DockPanel.Dock="Top" Background="#111111"
                Padding="16 12" CornerRadius="4" Margin="0 0 0 16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Ejercicio:" VerticalAlignment="Center"
                           Margin="0 0 8 0" Foreground="#AAAAAA"/>
                <ComboBox x:Name="CmbEjercicio"
                          Width="220" Margin="0 0 24 0"
                          SelectionChanged="CmbEjercicio_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Nombre}" Foreground="White"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Métrica:" VerticalAlignment="Center"
                           Margin="0 0 8 0" Foreground="#AAAAAA"/>
                <ComboBox x:Name="CmbMetrica"
                         
                          Width="180"
                          SelectionChanged="CmbMetrica_SelectionChanged"/>
            </StackPanel>
        </Border>

        <!-- Gráfica LiveCharts2 (instanciada desde code-behind) -->
        <Border x:Name="ChartContainer" Background="#111111" CornerRadius="4" Padding="8"/>
    </DockPanel>
</UserControl>
